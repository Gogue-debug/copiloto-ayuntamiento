# =============================================================================
# COPILOTO ADMINISTRATIVO — Variables de entorno
# Copiar a .env y rellenar los valores. NUNCA commitear .env
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic / Claude API
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=copiloto
POSTGRES_USER=copiloto
POSTGRES_PASSWORD=changeme_dev
DATABASE_URL=postgresql+asyncpg://copiloto:changeme_dev@localhost:5432/copiloto

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# MinIO (almacenamiento objetos)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_dev
MINIO_BUCKET=copiloto
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# Keycloak (autenticación)
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=copiloto
KEYCLOAK_CLIENT_ID=copiloto-api
KEYCLOAK_CLIENT_SECRET=changeme_dev
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_dev

# -----------------------------------------------------------------------------
# FastAPI / Aplicación
# -----------------------------------------------------------------------------
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=changeme_dev_secret_key_min_32_chars
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Google Cloud Document AI (OCR)
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id
DOCUMENT_AI_PROCESSOR_ID=your-processor-id
DOCUMENT_AI_LOCATION=eu

# -----------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API)
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=changeme_webhook_verify_token
WHATSAPP_API_VERSION=v19.0

# -----------------------------------------------------------------------------
# Notificaciones (email)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@copiloto.es
SMTP_TLS=false

# -----------------------------------------------------------------------------
# Cl@ve SAML (identidad digital española) — solo producción
# -----------------------------------------------------------------------------
CLAVE_SP_ENTITY_ID=
CLAVE_SP_ACS_URL=
CLAVE_IDP_METADATA_URL=
CLAVE_SP_PRIVATE_KEY_PATH=
CLAVE_SP_CERTIFICATE_PATH=

# -----------------------------------------------------------------------------
# AutoFirma / @firma (firma digital) — solo producción
# -----------------------------------------------------------------------------
AUTOFIRMA_LOCAL_PORT=51234

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Traefik (solo producción)
# -----------------------------------------------------------------------------
TRAEFIK_ACME_EMAIL=admin@copiloto.es
BASE_DOMAIN=copiloto.es

# -----------------------------------------------------------------------------
# Monitorización
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
SENTRY_DSN=                  # opcional, para error tracking en producción
